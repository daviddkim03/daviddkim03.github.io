# Supabase credentials for the /admin content editor.
# Copy this file to ".env.local" (which is gitignored) and fill in your values.
# Both are safe to expose in the built site — Row-Level Security protects writes.
# NEVER put the Supabase service_role key here; only the anon/public key.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
